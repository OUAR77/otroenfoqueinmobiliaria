[Unit]
Description=Otro Enfoque Inmobiliaria
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/otroenfoque
EnvironmentFile=/var/www/otroenfoque/.env
ExecStart=/var/www/otroenfoque/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8022 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
